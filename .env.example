# ===== Backend =====
PORT=3000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/gerenciador-provas
MONGODB_DB_NAME=gerenciador-provas
MONGODB_POOL_MIN=5
MONGODB_POOL_MAX=10
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# Production (Vercel)
# MONGODB_URI=mongodb+srv://seu-usuario:sua-senha@seu-cluster.mongodb.net/gerenciador-provas

# Logging
LOG_LEVEL=info

# ===== Frontend =====
VITE_API_URL=http://localhost:3000/api

# Production (Vercel)
# VITE_API_URL=https://seu-dominio.vercel.app/api
# FRONTEND_URL=https://seu-dominio.vercel.app

