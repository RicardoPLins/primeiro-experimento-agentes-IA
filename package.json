{
  "name": "gerenciador-provas",
  "version": "1.0.0",
  "description": "Sistema de gerenciamento de provas com geração de PDFs e correção automatizada",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/backend",
    "packages/frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "backend:dev": "npm --workspace=@gerenciador-provas/backend run dev",
    "frontend:dev": "npm --workspace=@gerenciador-provas/frontend run dev",
    "backend:build": "npm --workspace=@gerenciador-provas/backend run build",
    "frontend:build": "npm --workspace=@gerenciador-provas/frontend run build",
    "test:bdd": "npm --workspace=@gerenciador-provas/backend run test:bdd"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.50.0",
    "typescript": "^5.3.3"
  }
}
